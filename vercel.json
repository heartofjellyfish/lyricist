{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install",
  "buildCommand": null,
  "outputDirectory": null,
  "framework": null,
  "rewrites": [
    {
      "source": "/wordlists/:path*",
      "has": [{ "type": "host", "value": "rhyme.qi.land" }],
      "destination": "/wordlists/:path*"
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "rhyme.qi.land" }],
      "destination": "/rhyme-finder/"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "rhyme.qi.land" }],
      "destination": "/rhyme-finder/:path*"
    }
  ]
}
